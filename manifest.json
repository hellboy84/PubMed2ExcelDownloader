{
  "manifest_version": 3,
  "name": "PubMed2ExcelDownloader",
  "version": "2.0.0",
  "description": "PubMed検索結果の書誌情報をExcel/CSVでダウンロードします。Export PubMed search results as Excel (.xlsx) or CSV.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "https://eutils.ncbi.nlm.nih.gov/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/p2e_16pix.png",
      "32":  "icons/p2e_32pix.png",
      "48":  "icons/p2e_48pix.png",
      "128": "icons/p2e_128pix.png"
    },
    "default_title": "PubMed2ExcelDownloader"
  },

  "icons": {
    "16":  "icons/p2e_16pix.png",
    "32":  "icons/p2e_32pix.png",
    "48":  "icons/p2e_48pix.png",
    "128": "icons/p2e_128pix.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "pubmed2exceldownloader@hellboy84",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
