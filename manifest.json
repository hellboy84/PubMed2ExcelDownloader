{
  "manifest_version": 3,
  "name": "PubMed2ExcelDownloader",
  "version": "1.0.0",
  "description": "PubMed検索結果の書誌情報をExcel/CSVでダウンロードします",

  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://eutils.ncbi.nlm.nih.gov/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/p2e_16pix.png",
      "32":  "icons/p2e_32pix.png",
      "48":  "icons/p2e_48pix.png",
      "128": "icons/p2e_128pix.png"
    },
    "default_title": "PubMed2ExcelDownloader"
  },

  "icons": {
    "16":  "icons/p2e_16pix.png",
    "32":  "icons/p2e_32pix.png",
    "48":  "icons/p2e_48pix.png",
    "128": "icons/p2e_128pix.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "pubmed2exceldownloader@hellboy84",
      "strict_min_version": "128.0"
    }
  }
}
